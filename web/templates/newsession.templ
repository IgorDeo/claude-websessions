package templates

import "path/filepath"

templ NewSessionModal(defaultDir string, recentDirs []string, dockerAvailable bool) {
	<div class="modal-overlay" onclick="this.remove()">
		<div class="modal-content" onclick="event.stopPropagation()">
			<h2>New Session</h2>
			if len(recentDirs) > 0 {
				<div class="recent-projects">
					<label class="recent-label">Recent Projects</label>
					<div class="recent-list">
						for _, dir := range recentDirs {
							<div
								class="recent-item"
								role="button"
								tabindex="0"
								onclick="window.websessions.quickSession(this)"
								data-dir={ dir }
								data-name={ filepath.Base(dir) }
							>
								<span class="recent-name">{ filepath.Base(dir) }</span>
								<span class="recent-path">{ dir }</span>
							</div>
						}
					</div>
				</div>
				<div class="modal-divider">
					<span>or create manually</span>
				</div>
			}
			<form id="new-session-form" hx-post="/sessions" hx-swap="none">
				<input type="hidden" id="resume_id" name="resume_id" value=""/>
				<div class="form-group">
					<label for="name">Session Name</label>
					<input type="text" id="name" name="name" placeholder="my-session" required/>
				</div>
				<div class="form-group" style="position:relative;">
					<label for="work_dir">Working Directory</label>
					<input type="text" id="work_dir" name="work_dir" value={ defaultDir } required autocomplete="off"
						oninput="window.websessions.dirAutocomplete(this)"
						onchange="window.websessions.loadClaudeSessions(this.value)"/>
					<div id="dir-suggestions" class="dir-suggestions"></div>
				</div>
				<div id="claude-sessions-section" class="claude-sessions-section" style="display:none;">
					<label class="recent-label">Resume previous Claude session</label>
					<div id="claude-sessions-list" class="recent-list"></div>
				</div>
				<div class="form-group">
					<label for="prompt">Initial Prompt (optional)</label>
					<textarea id="prompt" name="prompt" rows="3" placeholder="What should Claude work on?"></textarea>
				</div>
				<div class="form-group">
				<label style="display:flex; align-items:center; gap:0.5rem; cursor:pointer; font-size:0.8rem; color:var(--text-secondary); font-weight:500;">
						if dockerAvailable {
							<input type="checkbox" name="sandbox" value="true" style="width:16px; height:16px; flex-shrink:0; accent-color:var(--accent);"/>
						} else {
							<input type="checkbox" name="sandbox" value="true" disabled style="width:16px; height:16px; flex-shrink:0;"/>
						}
						Run in Docker sandbox
					</label>
					if !dockerAvailable {
						<span class="settings-hint">Docker Desktop is required for sandbox mode</span>
					}
				</div>
				<div class="form-actions">
					<button type="button" class="btn-cancel" onclick="this.closest('.modal-overlay').remove()">Cancel</button>
					<button type="submit" class="btn-create">Create</button>
				</div>
			</form>
		</div>
	</div>
}
