package templates

import "strings"

templ Sidebar(sessions []SessionView, history []SessionView) {
	<div class="sidebar-tabs">
		<button class="sidebar-tab sidebar-tab-active" onclick="window.websessions.switchSidebarTab('active', this)">Active</button>
		<button class="sidebar-tab" onclick="window.websessions.switchSidebarTab('history', this)">
			History
			if len(history) > 0 {
				<span class="sidebar-tab-count">{ itoa(len(history)) }</span>
			}
		</button>
	</div>
	<div class="sidebar-search">
		<input type="text" id="session-search" placeholder="Search sessions..." oninput="window.websessions.filterSessions(this.value)"/>
	</div>
	<div id="bulk-actions" class="bulk-actions" style="display:none">
		<span id="bulk-count">0 selected</span>
		<div class="bulk-action-btn" onclick="window.websessions.bulkKill()">Kill</div>
		<div class="bulk-action-btn" onclick="window.websessions.bulkClearSelection()">Cancel</div>
	</div>
	<div id="sidebar-active" class="sidebar-panel sidebar-panel-visible">
		<div class="session-list" id="session-list">
			@sidebarSessions(sessions)
		</div>
	</div>
	<div id="sidebar-history" class="sidebar-panel">
		<div class="history-list">
			for _, s := range history {
				<div class={ "session-item", stateClass(s.State) }>
					<span class="status-dot"></span>
					<div class="session-info">
						<span class="session-name">{ s.Name }</span>
						<span class="session-dir" title={ s.WorkDir }>
							for i, seg := range pathBreadcrumbs(s.WorkDir) {
								if i > 0 {
									<span class="path-sep">/</span>
								}
								<span class="path-segment">{ seg }</span>
							}
						</span>
						<span class="session-status-label">{ s.State }</span>
					</div>
					<button
						class="restart-btn"
						hx-post={ "/sessions/" + s.ID + "/restart" }
						hx-target="#terminal-area"
						hx-swap="innerHTML"
					>Restart</button>
				</div>
			}
			if len(history) == 0 {
				<div class="sidebar-empty">No session history</div>
			}
		</div>
	</div>
}

templ sidebarSessions(sessions []SessionView) {
	for _, gn := range uniqueGroups(sessions) {
		<div class="session-group">
			<div class="session-group-header" onclick="window.websessions.toggleGroupCollapsed(this)">
				<span class="session-group-chevron">&#9662;</span>
				<span class="session-group-name">{ gn }</span>
				<span class="session-group-count">{ itoa(countInGroup(gn, sessions)) }</span>
			</div>
			<div class="session-group-body">
				for _, gs := range sessionsInGroup(gn, sessions) {
					@sessionItem(gs, true)
				}
			</div>
		</div>
	}
	for _, s := range sessions {
		if s.GroupName == "" {
			@sessionItem(s, false)
		}
	}
	if len(sessions) == 0 {
		<div class="sidebar-empty">No active sessions</div>
	}
}

templ sessionItem(s SessionView, grouped bool) {
	<div
		class={ "session-item", stateClass(s.State), templ.KV("session-item-grouped", grouped) }
		data-session-id={ s.ID }
		draggable="true"
		ondragstart="window.websessions.dragStart(event)"
		ondragover="window.websessions.dragOver(event)"
		ondrop="window.websessions.drop(event)"
		ondragend="window.websessions.dragEnd(event)"
		oncontextmenu={ colorPickerAction(s.ID) }
	>
		if s.Color != "" {
			<div class="session-color-bar" style={ "background-color:" + s.Color }></div>
		}
		if s.State != "offline" && s.State != "discovered" {
			<input type="checkbox" class="session-checkbox" data-session-id={ s.ID } onclick="window.websessions.toggleSessionSelect(this, event)"/>
		}
		if !grouped {
			<div class="drag-handle" title="Drag to reorder">&#8801;</div>
		}
		if s.State != "offline" {
			<div
				class="session-clickable"
				onclick={ openSession(s.ID, s.Name, s.State) }
			>
				<span class="status-dot"></span>
				<div class="session-info">
					<div class="session-name-row">
						<span class="session-name">{ s.Name }</span>
						<span class={ "session-type-badge", "type-" + s.Type }>{ s.Type }</span>
						if s.Sandboxed {
							<span class="sandbox-badge" title="Running in Docker sandbox VM">&#128737;</span>
						}
					</div>
					<span class="session-dir" title={ s.WorkDir }>
						for i, seg := range pathBreadcrumbs(s.WorkDir) {
							if i > 0 {
								<span class="path-sep">/</span>
							}
							<span class="path-segment">{ seg }</span>
						}
					</span>
					if s.Note != "" {
						<span class="session-note">{ s.Note }</span>
					}
				</div>
			</div>
		} else {
			<div class="session-clickable">
				<span class="status-dot"></span>
				<div class="session-info">
					<div class="session-name-row">
						<span class="session-name">{ s.Name }</span>
						<span class={ "session-type-badge", "type-" + s.Type }>{ s.Type }</span>
						if s.Sandboxed {
							<span class="sandbox-badge" title="Running in Docker sandbox VM">&#128737;</span>
						}
					</div>
					<span class="session-dir" title={ s.WorkDir }>
						for i, seg := range pathBreadcrumbs(s.WorkDir) {
							if i > 0 {
								<span class="path-sep">/</span>
							}
							<span class="path-segment">{ seg }</span>
						}
					</span>
					if s.Note != "" {
						<span class="session-note">{ s.Note }</span>
					}
				</div>
			</div>
		}
		if s.State == "discovered" {
			<button class="takeover-btn" hx-post={ "/sessions/" + s.ID + "/takeover" } hx-target="#terminal-area" hx-swap="innerHTML">Take Over</button>
		}
		if s.State == "offline" {
			<button class="restart-btn" hx-post={ "/sessions/" + s.ID + "/restart" } hx-target="#terminal-area" hx-swap="innerHTML">Restart</button>
		}
	</div>
}

script openSession(id string, name string, state string) {
	window.websessions.openTab(id, name, state);
}

script colorPickerAction(id string) {
	event.preventDefault();
	window.websessions.showColorPicker(id, event);
}

func stateClass(state string) string {
	switch state {
	case "running": return "state-running"
	case "completed": return "state-completed"
	case "errored": return "state-errored"
	case "waiting": return "state-waiting"
	case "starting": return "state-starting"
	case "discovered": return "state-discovered"
	case "offline": return "state-offline"
	case "killed": return "state-errored"
	default: return ""
	}
}

func uniqueGroups(sessions []SessionView) []string {
	seen := make(map[string]bool)
	var groups []string
	for _, s := range sessions {
		if s.GroupName != "" && !seen[s.GroupName] {
			seen[s.GroupName] = true
			groups = append(groups, s.GroupName)
		}
	}
	return groups
}

func sessionsInGroup(groupName string, sessions []SessionView) []SessionView {
	var result []SessionView
	for _, s := range sessions {
		if s.GroupName == groupName {
			result = append(result, s)
		}
	}
	return result
}

func countInGroup(groupName string, sessions []SessionView) int {
	count := 0
	for _, s := range sessions {
		if s.GroupName == groupName {
			count++
		}
	}
	return count
}

func pathBreadcrumbs(fullPath string) []string {
	parts := strings.Split(fullPath, "/")
	if len(parts) <= 3 {
		return parts
	}
	return append([]string{"..."}, parts[len(parts)-2:]...)
}
