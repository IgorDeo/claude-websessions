package templates

import "fmt"
import "path/filepath"

templ Notifications(notifications []NotificationView) {
	<div class="notif-panel">
		<div class="notif-panel-header">
			<span class="notif-panel-title">Notifications</span>
			if len(notifications) > 0 {
				<span class="notif-panel-count">{ fmt.Sprintf("%d", len(notifications)) }</span>
				<button class="notif-clear-all" onclick="window.websessions.clearAllNotifications()">Clear all</button>
			}
		</div>
		<div class="notif-panel-body">
			if len(notifications) == 0 {
				<div class="notif-empty">
					<span>All caught up</span>
				</div>
			}
			for _, n := range notifications {
				<div
					class={ "notif-item", "notif-" + n.EventType }
					id={ fmt.Sprintf("notif-%d", n.ID) }
					onclick={ openNotifSession(n.SessionID, n.SessionName, n.EventType) }
				>
					<div class="notif-item-icon">
						if n.EventType == "completed" {
							<span class="notif-icon-completed">&#10003;</span>
						}
						if n.EventType == "errored" {
							<span class="notif-icon-errored">&#10007;</span>
						}
						if n.EventType == "waiting" {
							<span class="notif-icon-waiting">&#9888;</span>
						}
						if n.EventType == "killed" {
							<span class="notif-icon-errored">&#9632;</span>
						}
					</div>
					<div class="notif-item-content">
						<div class="notif-item-top">
							<span class="notif-item-title">{ n.SessionName }</span>
							<span class="notif-item-time" title={ n.Timestamp }>{ n.TimeAgo }</span>
						</div>
						<span class="notif-item-message">{ n.Message }</span>
						<div class="notif-item-meta">
							if n.WorkDir != "" {
								<span class="notif-item-dir">{ filepath.Base(n.WorkDir) }</span>
								<span class="notif-item-path">{ n.WorkDir }</span>
							}
							<span class={ "notif-item-state", "notif-state-" + n.EventType }>{ n.EventType }</span>
						</div>
					</div>
					<div class="notif-item-actions">
						if n.EventType == "waiting" {
							<button class="notif-item-snooze" onclick={ snoozeNotifEvent(n.ID, n.SessionID) } title="Snooze 15 min">&#128340;</button>
						}
						<button class="notif-item-dismiss" onclick={ dismissNotifEvent(n.ID) } title="Dismiss">&#10005;</button>
					</div>
				</div>
			}
		</div>
	</div>
}

script openNotifSession(sessionID string, sessionName string, eventType string) {
	window.websessions.focusNotifSession(sessionID, sessionName, eventType);
}

script dismissNotifEvent(id int64) {
	event.stopPropagation();
	window.websessions.dismissNotification(id);
}

script snoozeNotifEvent(id int64, sessionID string) {
	event.stopPropagation();
	window.websessions.snoozeNotification(id, sessionID);
}
