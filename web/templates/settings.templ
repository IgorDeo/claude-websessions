package templates

type SettingsData struct {
	Port             int
	Host             string
	ScanInterval     string
	OutputBufferSize string
	DefaultDir       string
	DesktopNotifs    bool
	NotifCompleted   bool
	NotifErrored     bool
	NotifWaiting     bool
	ReminderMinutes  int
	HooksInstalled   bool
	ServiceInstalled bool
	ServiceActive    bool
	ServiceEnabled   bool
	ServiceStatus    string
	ServiceName      string
	Version          string
	Doctor           []DoctorCheck
}

type DoctorCheck struct {
	Name    string
	Status  string // "ok", "missing", "warning"
	Version string
	Detail  string
}

templ Settings(data SettingsData) {
	@Layout("websessions - Settings") {
		<div class="app">
			<header class="topbar">
				<h1 class="topbar-title"><a href="/" class="topbar-link">websessions</a> / Settings</h1>
			</header>
			<div class="settings-page">
				<div class="settings-section doctor-section">
					<h3>System Health</h3>
					<div class="doctor-grid">
						for _, check := range data.Doctor {
							<div class={ "doctor-item", "doctor-" + check.Status }>
								<div class="doctor-icon">
									if check.Status == "ok" {
										<span>&#10003;</span>
									}
									if check.Status == "missing" {
										<span>&#10007;</span>
									}
									if check.Status == "warning" {
										<span>&#9888;</span>
									}
								</div>
								<div class="doctor-info">
									<span class="doctor-name">{ check.Name }</span>
									if check.Version != "" {
										<span class="doctor-version">{ check.Version }</span>
									}
									if check.Detail != "" {
										<span class="doctor-detail">{ check.Detail }</span>
									}
								</div>
							</div>
						}
					</div>
				</div>
				<form id="settings-form" method="POST" action="/settings">
					<div class="settings-section">
						<h3>Server</h3>
						<div class="settings-row">
							<label for="port">Port</label>
							<input type="number" id="port" name="port" value={ itoa(data.Port) }/>
						</div>
						<div class="settings-row">
							<label for="host">Host</label>
							<input type="text" id="host" name="host" value={ data.Host }/>
						</div>
					</div>
					<div class="settings-section">
						<h3>Sessions</h3>
						<div class="settings-row">
							<label for="scan_interval">Discovery Scan Interval</label>
							<input type="text" id="scan_interval" name="scan_interval" value={ data.ScanInterval } placeholder="30s"/>
						</div>
						<div class="settings-row">
							<label for="output_buffer_size">Output Buffer Size</label>
							<input type="text" id="output_buffer_size" name="output_buffer_size" value={ data.OutputBufferSize } placeholder="10MB"/>
						</div>
						<div class="settings-row" style="position:relative;">
							<label for="default_dir">Default Working Directory</label>
							<input type="text" id="default_dir" name="default_dir" value={ data.DefaultDir }
								autocomplete="off" oninput="window.websessions.settingsDirAutocomplete(this)"/>
							<div id="settings-dir-suggestions" class="dir-suggestions"></div>
						</div>
					</div>
					<div class="settings-section">
						<h3>Notifications</h3>
						<div class="settings-row">
							<label class="checkbox-label">
								if data.DesktopNotifs {
									<input type="checkbox" name="desktop_notifs" checked/>
								} else {
									<input type="checkbox" name="desktop_notifs"/>
								}
								Desktop Notifications
							</label>
						</div>
					<div class="settings-row">
							<label class="checkbox-label">
								<input type="checkbox" id="notif-sounds-toggle" onchange="window.websessions.setNotifSoundsEnabled(this.checked)"/>
								Notification Sounds
							</label>
							<div class="sound-test-btns">
								<button type="button" class="btn-sound" onclick="window.websessions.testNotifSound('completed')" title="Test completed sound">&#9835; Completed</button>
								<button type="button" class="btn-sound" onclick="window.websessions.testNotifSound('waiting')" title="Test waiting sound">&#9835; Waiting</button>
								<button type="button" class="btn-sound" onclick="window.websessions.testNotifSound('errored')" title="Test error sound">&#9835; Error</button>
							</div>
						</div>
						<div class="settings-row">
							<span class="settings-sublabel">Notify on:</span>
							<div class="checkbox-group">
								<label class="checkbox-label">
									if data.NotifCompleted {
										<input type="checkbox" name="notif_completed" checked/>
									} else {
										<input type="checkbox" name="notif_completed"/>
									}
									Completed
								</label>
								<label class="checkbox-label">
									if data.NotifErrored {
										<input type="checkbox" name="notif_errored" checked/>
									} else {
										<input type="checkbox" name="notif_errored"/>
									}
									Errored
								</label>
								<label class="checkbox-label">
									if data.NotifWaiting {
										<input type="checkbox" name="notif_waiting" checked/>
									} else {
										<input type="checkbox" name="notif_waiting"/>
									}
									Waiting for Input
								</label>
							</div>
						</div>
						<div class="settings-row">
							<label for="reminder_minutes">Reminder interval (minutes)</label>
							<input type="number" id="reminder_minutes" name="reminder_minutes" value={ itoa(data.ReminderMinutes) } min="0" placeholder="5"/>
							<span class="settings-hint">0 = disabled. Re-notifies if a session waits without action.</span>
						</div>
					</div>
					<div class="settings-actions">
						<a href="/" class="btn-cancel">Cancel</a>
						<button type="submit" class="btn-create">Save Settings</button>
					</div>
					<p class="settings-note">Some changes (port, host) require a server restart to take effect.</p>
				</form>
				<div class="settings-section" id="hooks-section">
					<h3>Claude Code Hooks</h3>
					<p class="hooks-description">
						Hooks notify websessions when Claude needs your input (tool approval prompts).
						This adds an entry to <code>~/.claude/settings.json</code>.
					</p>
					<div class="settings-row hooks-status" id="hooks-status">
						if data.HooksInstalled {
							<span class="hooks-badge hooks-active">Installed</span>
							<button type="button" class="btn-cancel btn-small" onclick="window.websessions.manageHooks('uninstall')">Uninstall</button>
						} else {
							<span class="hooks-badge hooks-inactive">Not installed</span>
							<button type="button" class="btn-create btn-small" onclick="window.websessions.manageHooks('install')">Install Hooks</button>
						}
					</div>
					<div id="hooks-feedback"></div>
					<div class="hooks-events">
						<span class="settings-sublabel">Hook events:</span>
						<ul class="hooks-event-list">
							<li><strong>Notification</strong> (permission_prompt) — fires when Claude needs you to approve a tool use</li>
						</ul>
					</div>
				</div>
				<div class="settings-section" id="service-section">
					<h3>Background Service</h3>
					<p class="hooks-description">
						Run websessions as a { data.ServiceName } service so it starts automatically
						on login and stays running in the background.
					</p>
					<div class="settings-row hooks-status" id="service-status">
						if data.ServiceInstalled {
							if data.ServiceActive {
								<span class="hooks-badge hooks-active">Running</span>
							} else {
								<span class="hooks-badge hooks-inactive">Stopped</span>
							}
							if data.ServiceEnabled {
								<span class="service-label">starts on login</span>
							}
							<div class="service-actions">
								if data.ServiceActive {
									<button type="button" class="btn-cancel btn-small" onclick="window.websessions.manageService('stop')">Stop</button>
								} else {
									<button type="button" class="btn-create btn-small" onclick="window.websessions.manageService('start')">Start</button>
								}
								if data.ServiceEnabled {
									<button type="button" class="btn-cancel btn-small" onclick="window.websessions.manageService('disable')">Disable autostart</button>
								} else {
									<button type="button" class="btn-small service-enable-btn" onclick="window.websessions.manageService('enable')">Enable autostart</button>
								}
								<button type="button" class="btn-cancel btn-small" onclick="window.websessions.manageService('uninstall')">Uninstall</button>
							</div>
						} else {
							<span class="hooks-badge hooks-inactive">Not installed</span>
							<button type="button" class="btn-create btn-small" onclick="window.websessions.manageService('install')">Install Service</button>
						}
					</div>
					<div id="service-feedback"></div>
				</div>
				<div class="settings-section" id="update-section">
					<h3>Updates</h3>
					<div class="settings-row">
						<span class="settings-sublabel">Current version</span>
						<span class="update-version">{ data.Version }</span>
					</div>
					<div class="settings-row" id="update-status">
						<button type="button" class="btn-create btn-small" onclick="window.websessions.checkForUpdate()">Check for updates</button>
					</div>
					<div id="update-feedback"></div>
				</div>
			</div>
		</div>
	}
}
